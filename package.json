{
  "name": "gemini-chatbot-api",
  "version": "1.0.0",
  "description": "Chatbot sederhana berbasis Gemini AI (Node.js + Express + Vanilla JS)",
  "type": "module",
  "main": "index.js",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "esbuild public/app.jsx --bundle --format=esm --jsx=automatic --minify --target=es2020 --outfile=public/app.js",
    "start": "node index.js",
    "dev": "node --watch index.js",
    "test": "node --test"
  },
  "keywords": [
    "gemini",
    "chatbot",
    "express",
    "hacktiv8"
  ],
  "license": "MIT",
  "dependencies": {
    "@google/genai": "^1.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.5.1",
    "lucide-react": "^0.460.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "esbuild": "^0.21.5"
  }
}
