# Salin file ini menjadi .env lalu isi nilainya.
# cp .env.example .env

# Gemini API key kamu (wajib). Dapatkan di https://aistudio.google.com/app/apikey
GEMINI_API_KEY=PASTE_API_KEY_KAMU_DISINI

# Opsional: ganti model Gemini di sini.
# Contoh: gemini-2.5-flash, gemini-2.0-flash
GEMINI_MODEL=gemini-2.5-flash

# Opsional: port server (default 3000)
PORT=3000

# --- ElevenLabs (Text-to-Speech / suara Kira) ------------------------------
# Suara Kira pakai ElevenLabs supaya natural. Dapatkan key di https://elevenlabs.io
# Kalau dikosongkan, app otomatis fallback ke suara bawaan browser.
# ELEVENLABS_API_KEY=PASTE_ELEVENLABS_KEY_KAMU
# Voice default "Sarah" (perempuan, natural). Lihat daftar voice di dashboard ElevenLabs.
# ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL
# ELEVENLABS_MODEL=eleven_multilingual_v2

# --- Auth & Database -------------------------------------------------------
# Wajibkan login untuk pakai endpoint chat (1 = wajib, kosong/0 = bebas).
# Aktifkan ini di produksi supaya kuota Gemini tidak dipakai sembarang orang.
REQUIRE_AUTH=0

# Lokasi file database SQLite (default data/kira.db).
# DB_PATH=data/kira.db

# Masa berlaku token login dalam milidetik (default 30 hari).
# AUTH_TOKEN_TTL_MS=2592000000

# --- Observability ---------------------------------------------------------
# Level log: debug | info | warn | error (default info).
# LOG_LEVEL=info

# Token untuk mengakses GET /api/metrics (header x-metrics-token).
# Kalau kosong, endpoint metrics terbuka (sebaiknya diisi di produksi).
# METRICS_TOKEN=
